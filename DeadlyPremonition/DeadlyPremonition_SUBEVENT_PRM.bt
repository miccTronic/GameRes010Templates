    // Optional small qualifier. Observed values are 0, 1, or 0xFF.
    ubyte bool1 <format=hex>;
    // Local subevent (subquest) id/ordinal. Observed values cover 1..50, with a few
    // duplicate ids used for alternate rows.
    ubyte subeventId;
    // Optional variant flag. Only observed non-null value is 1.
    ubyte bool2 <format=hex>;
    // Boolean-looking enable/visibility flag. Observed values are 0 or 1.
