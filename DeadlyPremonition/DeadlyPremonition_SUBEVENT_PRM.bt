    ubyte unused42 <format=hex>;
    // Optional secondary related/prerequisite id. Only observed non-null value
    // is 22.
    ubyte relatedId1 <format=hex>;

    // First availability/progress range start. Always paired with
    // availabilityEnd0 and never 0xFF in the known PC file.
    ubyte availabilityStart0;
    // First availability/progress range end.
    ubyte availabilityEnd0;
    // Optional second availability/progress range start; 0xFF means absent.
    ubyte availabilityStart1 <format=hex>;
    // Optional second availability/progress range end; paired with
    // availabilityStart1. The recurring observed second range is 25..26.
    ubyte availabilityEnd1 <format=hex>;
} DpSubeventPrmRecord <read=Str(
    "row=%d  subevent=%u  progress=%u  enabled=%i  range=%i..%i  %i..%i",
    recordIndex, subeventId, progressOrChapterId, enabledFlag,
