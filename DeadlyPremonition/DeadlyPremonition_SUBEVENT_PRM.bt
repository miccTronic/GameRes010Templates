    ubyte dependencyMode;
    // Dependency target or parameter for dependencyMode. A value of 0 usually
    // means no target; non-zero values often match local subevent ids.
    ubyte dependencySubeventId;
    // Optional null-padded locator/position name used by event TABLE PRMs too.
    // "none" is the null/sentinel string. Examples: 08_01counter,
    // 10_03front, 26_02park_01carrol.cry.pos.
