{
    char magic[4];
    uint fileSize;
    ushort textureCount <comment="Populated/nonblank texture entries, not slot count">;
    ushort materialCount;
    ushort usedTextureCount <comment="Per-material slot count: usually 5 for model textures, 1 for single-image/UI archives">;
    ushort unknown0E;
    ubyte reserved10[0x10] <fgcolor=0xA0A0A0>;
    uint textureIndexOffset <format=hex>;
    uint dataOffset <format=hex>;
} DpXpc2Header <read=Str("%s size=%u populated=%u materials=%u slots=%u", this.magic, this.fileSize, this.textureCount, this.materialCount, this.usedTextureCount)>;

string DpXpcSlotName(uint slotIndex)
{
    switch (slotIndex)
    {
        case 0: return "Diffuse";
        case 1: return "Normal";
        case 2: return "Specular";
        case 3: return "Emissive/Env";
        case 4: return "Mask/Effect";
        default: return "Extra";
    }
}

typedef struct(uint materialIndex, uint slotIndex)
{
    char name[0x10];
    uint dataOffset <format=hex>;
    uint compressedSize;
    uint textureType <format=hex>;
    uint uncompressedSizeField;
    local uint noesisInflateSize = this.uncompressedSizeField / 256;
} DpXpc2TextureEntry <read=Str("mat=%u %s off=0x%X z=%u raw=0x%X", materialIndex, this.name, this.dataOffset, this.compressedSize, this.uncompressedSizeField)>;

typedef struct(uint materialIndex, uint slotCount)
{
    if (slotCount > 0) DpXpc2TextureEntry diffuse(materialIndex, 0);
    if (slotCount > 1) DpXpc2TextureEntry normal(materialIndex, 1);
    if (slotCount > 2) DpXpc2TextureEntry specular(materialIndex, 2);
    if (slotCount > 3) DpXpc2TextureEntry emissiveOrEnvironment(materialIndex, 3);
    if (slotCount > 4) DpXpc2TextureEntry maskOrEffect(materialIndex, 4);

    local uint extraSlotIndex <hidden=true>;
    for (extraSlotIndex = 5; extraSlotIndex < slotCount; extraSlotIndex++)
    {
        DpXpc2TextureEntry extraSlot(materialIndex, extraSlotIndex);
    }
} DpXpc2Material <read=Str("material %u", materialIndex)>;

typedef struct(int length)
{
