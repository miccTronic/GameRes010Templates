#include "..\!Shared.bt"
// This template was generated by CODEX.
// Deadly Premonition .XPC texture container. XPC2 is mapped; XPC1 is kept as raw unknown data.
// XPC2 index entries are grouped by material. Header textureCount is the populated
// texture count; usedTextureCount is the number of fixed slots per material.

LittleEndian();

local int FileLength = FileSize();
local uint Magic = 0;
if (FileLength >= 4) Magic = ReadUInt(0);

int IsValidRange(uint offset, uint byteCount, uint fileLength)
{
    if (offset == 0) return 0;
    if (offset > fileLength) return 0;
    if (byteCount > fileLength - offset) return 0;
    return 1;
}

