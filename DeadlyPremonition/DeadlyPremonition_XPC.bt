        ubyte data[length] <optimize=true>;
    }
} DpRawBytes;

typedef struct
{
    char magic[4];
    if (FileLength > 4)
    {
        DpRawBytes body(FileLength - 4);
    }
} DpXpc1Unknown <read=Str("%s unknown XPC1 variant", this.magic)>;

if (Magic == 0x32435058) // XPC2
{
    DpXpc2Header header;
    local uint SlotsPerMaterial = header.usedTextureCount != 0 ? header.usedTextureCount : header.textureCount;
    if (SlotsPerMaterial == 0) SlotsPerMaterial = 1;
    local uint TextureRecordCount = header.materialCount * SlotsPerMaterial;

    if (header.textureIndexOffset > FTell())
    {
        DpRawBytes headerGap(header.textureIndexOffset - FTell());
    }

    if (IsValidRange(header.textureIndexOffset, TextureRecordCount * 0x20, FileLength))
    {
        FSeek(header.textureIndexOffset);
        local uint materialIndex;
        for (materialIndex = 0; materialIndex < header.materialCount; materialIndex++)
        {
            DpXpc2Material material(materialIndex, SlotsPerMaterial);
        }
    }

    if (IsValidRange(header.dataOffset, FileLength - header.dataOffset, FileLength))
    {
        FSeek(header.dataOffset);
        DpRawBytes compressedTextureData(FileLength - header.dataOffset);
    }
}
else if (Magic == 0x31435058) // XPC1
{
    DpXpc1Unknown xpc1;
}
else
{
    DpRawBytes unknownFile(FileLength);
}

