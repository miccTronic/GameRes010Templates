int DpDsbOpcodeColor(ushort opcode)
{
    if (opcode == DSB_OP_End) return 0xD8D8D8;
    switch (opcode >> 8)
    {
        case 0x01: return 0xE8F0FF;
        case 0x02: return 0xE8FFE8;
        case 0x03: return 0xE8FFFF;
        case 0x04: return 0xFFF4D8;
        case 0x05: return 0xFFE8E8;
        case 0x06: return 0xF4E8FF;
        case 0x07: return 0xE8E8FF;
        case 0x08: return 0xFFFFD8;
        default: return 0xF0F0F0;
    }
}

