    local int codeByteCount <hidden=true> = byteCount;
    local int blockStart <hidden=true> = FTell();
    local int blockEnd <hidden=true> = blockStart + byteCount;
    local int chunkIndex <hidden=true> = 0;
    local int chunkStartBefore <hidden=true>;

    while (FTell() + 8 <= blockEnd)
    {
        chunkStartBefore = FTell();
        DpDsbCodeChunk chunk(blockEnd) <optimize=false, bgcolor=0xF8FFF8>;
        chunkIndex++;
        if (FTell() <= chunkStartBefore) break;
    }

    if (FTell() < blockEnd)
    {
        DpRawBytes trailingBytes(blockEnd - FTell()) <bgcolor=0xE0E0E0>;
    }
} DpDsbCodeBlock <read=Str("chunks=%u codeBytes=%u", this.chunkIndex, this.codeByteCount)>;

typedef struct
{
    char magic[4];
    uint zero04;
    uint formatVersion;
    uint zero0C;
    uint fileSize;
    uint sectionOffset <format=hex>;
    uint recordTableOffset <format=hex>;
    uint codeOffset <format=hex>;
    uint one20;
    uint recordCount;
    ushort year;
    ubyte month;
    ubyte day;
    ubyte hour;
    ubyte minute;
    ubyte second;
    ubyte zero2F;
    char fileName[0x20];
    char category[0x20]; // e.g. "talk" for conversations
    ubyte zero70[0x10] <fgcolor=0xA0A0A0>;
} DpDsbHeader <read=Str("'%s'   (records=%u)", category, recordCount)>;

typedef struct
{
    uint scriptId; // usually matches file name
    uint zero84;
    uint recordCount;
    uint recordTableOffset <format=hex>;
    uint contextString1Offset <format=hex>;
    uint contextString2Offset <format=hex>;
    ZeroInt32 zero98;
    ZeroInt32 zero9C;
} DpDsbSectionHeader <read=Str("script=%u records=%u", this.scriptId, this.recordCount)>;

typedef struct
{
    ushort scriptIdLow;
    ushort blockId;
    uint flagsA <format=hex>;
    uint flagsB <format=hex>;
    int codeOffset <format=hex>;
    int nameOffset <format=hex>;
    int firstMsgId;
    ZeroInt32 zero18;
    ZeroInt32 zero1C;

    if (nameOffset > 0) {
        local int lastPos <hidden=true> = FTell();
        FSeek(nameOffset);
        string name;
        FSeek(lastPos);
    } else {
        local string name <hidden=true>;
    }

    if (codeOffset > 0 && codeOffset < DP_FileLength) {
        local int codeEnd <hidden=true> = DpDsbCodeBlockEnd(codeOffset);
        local int codeLength <hidden=true> = codeEnd - codeOffset;
        if (codeLength > 0 && DpRangeValid(codeOffset, codeLength)) {
            local int lastCodePos <hidden=true> = FTell();
            FSeek(codeOffset);
            DpDsbCodeBlock code(codeLength) <bgcolor=0xF8FFF8>;
            FSeek(lastCodePos);
        }
    }
} DpDsbRecord <read=Str("block=%i code=0x%X name=0x%X msg=%i flags=%i %i  -->  %s", blockId, codeOffset, nameOffset, firstMsgId, flagsA, flagsB, name)>;

if (DP_FileLength >= 0xA0 && ReadUInt(0) == 0x44534236)
{
    DpDsbHeader header;
    if (header.sectionOffset == 0x80)
    {
        FSeek(header.sectionOffset);
        DpDsbSectionHeader section;
    }
    if (header.recordTableOffset == 0xA0 && DpRangeValid(header.recordTableOffset, header.recordCount * 0x20))
    {
        FSeek(header.recordTableOffset);
        DpDsbRecord records[header.recordCount] <optimize=false>;
    }
    if (header.codeOffset <= DP_FileLength)
    {
        FSeek(header.codeOffset);
        DpRawBytes codeAndStringPool(DP_FileLength - header.codeOffset);
    }
}
else
{
    DpRawBytes unknownFile(DP_FileLength);
}





