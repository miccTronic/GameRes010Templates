} PreyIndoorAreaRecordHeader <read=Str("%s, object bytes %d", this.name, this.objectTreeDataSize)>;

typedef struct
{
    local int64 recordStart = FTell();

    PreyIndoorAreaRecordHeader header;
    int shapePointCount;

    if (shapePointCount < 0)
    {
        Warning("Negative indoor.dat shape point count at 0x%LX", recordStart);
    }
    else
    {
        if (shapePointCount > 0)
        {
            Vector3 shapePoints[shapePointCount];
        }

        if (header.objectTreeDataSize < 0)
        {
            Warning("Negative indoor.dat object tree size at 0x%LX", recordStart);
        }
        else if (header.objectTreeDataSize > 0)
        {
            local int64 objectTreeStart = FTell();
            local int64 objectTreeEnd = objectTreeStart + header.objectTreeDataSize;

            if (header.objectTreeDataSize > 4)
            {
                PreyIndoorOctreeNodeRecord0 objectTreeRoot;
            }

