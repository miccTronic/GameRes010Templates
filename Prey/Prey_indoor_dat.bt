if (FileSize() < 0x14)
{
    Warning("File is too small for SVisAreaManChunkHeader.");
}
else
{
    SVisAreaManChunkHeader header;

    if (header.nVersion != 6)
    {
        Warning("Unexpected indoor.dat version %d; expected 6.", header.nVersion);
    }

    if (header.nChunkSize != FileSize())
    {
        Warning("Header chunk size %d does not match file size %Ld.", header.nChunkSize, FileSize());
    }

    if (header.nVisAreasNum < 0 || header.nPortalsNum < 0 || header.nOcclAreasNum < 0)
    {
        Warning("Negative indoor.dat area count.");
    }
    else
    {
        if (header.nVisAreasNum > 0)
        {
            PreyIndoorAreaRecord visAreas[header.nVisAreasNum] <optimize=false>;
        }

        if (header.nPortalsNum > 0)
        {
            PreyIndoorAreaRecord portals[header.nPortalsNum] <optimize=false>;
        }

        if (header.nOcclAreasNum > 0)
        {
            PreyIndoorAreaRecord occlusionAreas[header.nOcclAreasNum] <optimize=false>;
        }

        if (FTell() != FileSize())
        {
            local int64 trailingSize = FileSize() - FTell();
            if (trailingSize > 0)
            {
                ubyte trailingData[trailingSize] <fgcolor=cRed>;
                Warning("indoor.dat parse ended before EOF; trailing bytes: %Ld.", trailingSize);
            }
            else
            {
                Warning("indoor.dat parse overran EOF by %Ld bytes.", -trailingSize);
            }
        }
    }
