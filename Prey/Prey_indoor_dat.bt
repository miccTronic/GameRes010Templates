} SVisAreaManChunkHeader <read=Str("version %d, vis %d, portals %d, occl %d", this.nVersion, this.nVisAreasNum, this.nPortalsNum, this.nOcclAreasNum)>;

typedef struct
{
    int areaType;              // Loader requires 2.
    BBox areaBox;              // CBasicArea::m_boxArea.
